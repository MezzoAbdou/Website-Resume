{"ast":null,"code":"import vueFlashcard from 'vue-flashcard';\nimport pic1 from '../assets/pic1.webp';\nimport lionel from '../assets/lionel.webp';\nimport dogs from '../assets/dogs.webp';\nimport pikachu from '../assets/pikachu.webp';\nexport default {\n  data() {\n    return {\n      questions: ['Who is this and what does she do?', 'Who is this and where is he from?', 'How many dogs are in this picture?', 'What is this  name, what is it?'],\n      answers: ['Whitney Houston, singer', 'Lionel Messi, Argentina', '8', 'Pikachu, a Pokemon'],\n      pic1,\n      lionel,\n      dogs,\n      pikachu,\n      pictures: [pic1, lionel, dogs, pikachu]\n    };\n  },\n  components: {\n    vueFlashcard\n  },\n  methods: {\n    playSound(index) {\n      const audio = new Audio();\n      audio.src = '/sound' + index + '.mp3';\n      audio.load();\n      audio.play();\n    }\n  }\n};","map":{"version":3,"mappings":"AA2BA,OAAOA,YAAW,MAAO,eAAe;AACxC,OAAOC,IAAG,MAAO,qBAAqB;AACtC,OAAOC,MAAK,MAAO,uBAAuB;AAC1C,OAAOC,IAAG,MAAO,qBAAqB;AACtC,OAAOC,OAAM,MAAO,wBAAwB;AAE5C,eAAe;EACXC,IAAI,GAAE;IACF,OAAO;MACHC,SAAS,EAAE,CAAC,mCAAmC,EAC/C,mCAAmC,EACnC,oCAAoC,EACpC,iCAAiC,CAAC;MAClCC,OAAO,EAAE,CAAC,yBAAyB,EACnC,yBAAyB,EACzB,GAAG,EACH,oBAAoB,CAAC;MACrBN,IAAI;MACJC,MAAM;MACNC,IAAI;MACJC,OAAO;MACPI,QAAQ,EAAE,CAACP,IAAI,EAAEC,MAAM,EAAEC,IAAI,EAAEC,OAAO;IAC1C;EACJ,CAAC;EACLK,UAAU,EAAE;IAACT;EAAY,CAAC;EAC1BU,OAAO,EAAE;IACDC,SAAS,CAACC,KAAK,EAAC;MACZ,MAAMC,KAAI,GAAI,IAAIC,KAAK,EAAE;MACzBD,KAAK,CAACE,GAAE,GAAI,QAAO,GAAIH,KAAI,GAAI,MAAM;MACrCC,KAAK,CAACG,IAAI,EAAE;MACZH,KAAK,CAACI,IAAI,EAAE;IAChB;EACJ;AAEJ","names":["vueFlashcard","pic1","lionel","dogs","pikachu","data","questions","answers","pictures","components","methods","playSound","index","audio","Audio","src","load","play"],"sourceRoot":"","sources":["/Users/lindsaypatterson/Desktop/lindsay-site/src/views/TriviaGameView.vue"],"sourcesContent":["<template>\n<div class=\"game\">\n          <h1>Can you answer the questions!?</h1>\n\n  <div class=\"trivia\">\n      <div class=\"flashcard\" v-for=\"(question, index) in questions\" \n      v-bind:key=\"index\"  v-on:click = \"playSound(index)\" >\n          <vue-flashcard  class=\"card\" v-bind:headerFront = \"questions[index]\"\n                v-bind:headerBack = \"answers[index]\"\n                v-bind:imgFront= \"pictures[index]\"\n                v-bind:imgBack= \"pictures[index]\"\n                footerFront = \"Click to show Answer\"\n                footerBack = \"Click to see Question\"\n                colorBack = \"orchid\"\n                colorFront = \"#D4E6F1\"\n                \n                \n                \n                />\n      </div>\n  </div>\n  </div>\n\n\n</template>\n\n<script>\nimport vueFlashcard from 'vue-flashcard';\nimport pic1 from '../assets/pic1.webp';\nimport lionel from '../assets/lionel.webp';\nimport dogs from '../assets/dogs.webp';\nimport pikachu from '../assets/pikachu.webp';\n\nexport default {\n    data(){\n        return {\n            questions: ['Who is this and what does she do?', \n            'Who is this and where is he from?', \n            'How many dogs are in this picture?', \n            'What is this  name, what is it?'],\n            answers: ['Whitney Houston, singer',\n            'Lionel Messi, Argentina',\n            '8',\n            'Pikachu, a Pokemon'],\n            pic1,\n            lionel,\n            dogs,\n            pikachu,\n            pictures: [pic1, lionel, dogs, pikachu],\n        } \n    },\ncomponents: {vueFlashcard},\nmethods: {\n        playSound(index){\n            const audio = new Audio();\n            audio.src = '/sound' + index + '.mp3';\n            audio.load();\n            audio.play();\n        }\n    }\n\n}\n</script>\n\n<style>\n.trivia{\n     margin: auto;\n  width: 50%;\n    \n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  \n  gap: 5px;\n  \ngrid-area: bottom;\njustify-items: center;   \n    \n}\n.game{\n    display: grid;\n    grid-template-columns: 1fr ;\n    grid-template-areas: \"top\"\n    \"bottom\";\n    \n}\nh1{\n    grid-area: top;\n}\n\n\n\n\n</style>"]},"metadata":{},"sourceType":"module","externalDependencies":[]}